# Copy this file to .env.local (gitignored) and fill in your values.
#
# ANTHROPIC_API_KEY
# -----------------
# API key used by /api/report to generate AI deforestation reports.
# Without this (or if the key is invalid / the request times out), the route
# falls back to the deterministic report generator in src/lib/generate-report.ts.
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ANTHROPIC_MODEL (optional)
ANTHROPIC_MODEL=
