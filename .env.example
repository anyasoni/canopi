# Copy this file to .env.local (gitignored) and fill in your values.
#
# ANTHROPIC_API_KEY
# -----------------
# API key used by /api/report to generate AI deforestation reports.
# Without this (or if the key is invalid / the request times out), the route
# falls back to the deterministic report generator in src/lib/generate-report.ts.
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ANTHROPIC_MODEL (optional)
ANTHROPIC_MODEL=

# ANTHROPIC_TIMEOUT_MS (optional)
# Per-attempt timeout for Anthropic requests in ms. Default: 30000. Max: 120000.
ANTHROPIC_TIMEOUT_MS=

# ANTHROPIC_MAX_ATTEMPTS (optional)
# Number of AI attempts before deterministic fallback. Default: 2.
ANTHROPIC_MAX_ATTEMPTS=

# ANTHROPIC_RETRY_BASE_MS (optional)
# Backoff base delay between attempts. Default: 400.
ANTHROPIC_RETRY_BASE_MS=

# ANTHROPIC_MAX_TOKENS (optional)
# Output token budget for AI report generation. Default: 1024.
ANTHROPIC_MAX_TOKENS=

# REPORT_CACHE_TTL_MS (optional)
# How long a successful AI report is kept in the in-memory server cache
# before being regenerated. Default: 3600000 (1h). Min: 1000, Max: 86400000 (24h).
REPORT_CACHE_TTL_MS=
